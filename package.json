{
  "name": "@language-lit/material3-expressive",
  "version": "0.3.0",
  "description": "Material 3 Expressive design system components for React",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/romulloqueiroz/material3-expressive.git"
  },
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./components/buttons": {
      "types": "./dist/components/buttons.d.ts",
      "import": "./dist/components/buttons.js",
      "default": "./dist/components/buttons.js"
    },
    "./components/cards": {
      "types": "./dist/components/cards.d.ts",
      "import": "./dist/components/cards.js",
      "default": "./dist/components/cards.js"
    },
    "./components/navigation": {
      "types": "./dist/components/navigation.d.ts",
      "import": "./dist/components/navigation.js",
      "default": "./dist/components/navigation.js"
    },
    "./components/inputs": {
      "types": "./dist/components/inputs.d.ts",
      "import": "./dist/components/inputs.js",
      "default": "./dist/components/inputs.js"
    },
    "./components/feedback": {
      "types": "./dist/components/feedback.d.ts",
      "import": "./dist/components/feedback.js",
      "default": "./dist/components/feedback.js"
    },
    "./components/modals": {
      "types": "./dist/components/modals.d.ts",
      "import": "./dist/components/modals.js",
      "default": "./dist/components/modals.js"
    },
    "./components/display": {
      "types": "./dist/components/display.d.ts",
      "import": "./dist/components/display.js",
      "default": "./dist/components/display.js"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "import": "./dist/hooks.js",
      "default": "./dist/hooks.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.js",
      "default": "./dist/utils.js"
    },
    "./context/Material3Provider": {
      "types": "./dist/context/Material3Provider.d.ts",
      "import": "./dist/context/Material3Provider.js",
      "default": "./dist/context/Material3Provider.js"
    },
    "./showcase": {
      "types": "./dist/showcase.d.ts",
      "import": "./dist/showcase.js",
      "default": "./dist/showcase.js"
    },
    "./tailwind-preset": {
      "types": "./dist/tailwind.preset.d.ts",
      "import": "./dist/tailwind.preset.js",
      "default": "./dist/tailwind.preset.js"
    },
    "./styles": "./dist/styles/main.css",
    "./v1": {
      "types": "./dist/v1/index.d.ts",
      "import": "./dist/v1/index.js",
      "default": "./dist/v1/index.js"
    },
    "./v1/styles.css": "./dist/v1/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && node scripts/add-directives.mjs && npm run build:styles",
    "build:styles": "node scripts/build-styles.mjs",
    "dev": "tsup --watch",
    "playground": "vite --config vite.config.ts",
    "playground:build": "vite build --config vite.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:v1": "vitest --run tests/v1",
    "typecheck:v1": "tsc --noEmit -p tsconfig.v1.json",
    "check:v1:architecture": "node scripts/check-v1-architecture.mjs",
    "check:v1:browsers": "node scripts/check-browser-support.mjs",
    "check:v1:styles": "node scripts/check-v1-css.mjs",
    "check:legacy-contract": "node scripts/legacy-contract.mjs",
    "update:legacy-contract": "npm run build && node scripts/legacy-contract.mjs --update",
    "check:consumer-fixtures": "node scripts/verify-consumer-fixtures.mjs",
    "check:bundle-size": "node scripts/check-bundle-size.mjs",
    "verify:v1": "node scripts/verify-v1.mjs",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "tailwindcss": "^3.0.0"
  },
  "dependencies": {
    "@floating-ui/react-dom": "^2.1.2",
    "@react-aria/button": "^3.14.2",
    "@react-aria/listbox": "^3.15.0",
    "@react-aria/select": "^3.17.0",
    "@react-aria/switch": "^3.8.1",
    "@react-stately/collections": "^3.12.0",
    "@react-stately/list": "^3.13.0",
    "@react-stately/select": "^3.8.0",
    "@react-stately/toggle": "^3.10.1",
    "@react-types/shared": "^3.32.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.3.19",
    "tailwind-merge": "^2.0.0 || ^3.0.0",
    "tailwind-variants": "^3.0.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "20.19.43",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "6.0.3",
    "fast-check": "^3.0.0",
    "jsdom": "^29.1.1",
    "lightningcss": "1.32.0",
    "next": "16.2.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.19"
    }
  },
  "keywords": [
    "material-design",
    "material-3",
    "react",
    "components",
    "ui",
    "design-system"
  ],
  "browserslist": [
    "Chrome >= 120",
    "Edge >= 120",
    "Firefox >= 121",
    "Safari >= 17.2",
    "iOS >= 17.2"
  ]
}
