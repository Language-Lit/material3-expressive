{
  "name": "@language-lit/material3-expressive",
  "version": "1.0.0",
  "description": "Material 3 Expressive design system components for React",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/romulloqueiroz/material3-expressive.git"
  },
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./theme": {
      "types": "./dist/theme.d.ts",
      "import": "./dist/theme.js",
      "default": "./dist/theme.js"
    },
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.js",
      "default": "./dist/tokens.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && node scripts/add-directives.mjs && npm run build:styles",
    "build:styles": "node scripts/build-styles.mjs",
    "dev": "tsup --watch",
    "playground": "vite --config playground/vite.dev.config.ts --port 5173 --strictPort",
    "playground:build": "vite build --config playground/vite.config.ts",
    "playground:preview": "vite preview --config playground/vite.config.ts --port 4173 --strictPort",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "check:architecture": "node scripts/check-architecture.mjs",
    "check:docs": "node scripts/check-docs.mjs",
    "generate:docs": "node scripts/check-docs.mjs --write",
    "check:release": "node scripts/check-release.mjs",
    "check:browsers": "node scripts/check-browser-support.mjs",
    "check:styles": "node scripts/check-css.mjs",
    "check:tokens": "node scripts/check-tokens.mjs",
    "check:consumer-fixtures": "node scripts/verify-consumer-fixtures.mjs",
    "check:bundle-size": "node scripts/check-bundle-size.mjs",
    "check:site": "node scripts/check-site.mjs",
    "generate:site-demos": "node scripts/generate-site-demos.mjs",
    "generate:site-symbols": "node scripts/fetch-symbols-font.mjs",
    "site:dev": "npm --prefix site run dev",
    "site:build": "npm --prefix site run build",
    "verify": "node scripts/verify.mjs",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "20.19.43",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "6.0.3",
    "jsdom": "^29.1.1",
    "lightningcss": "1.32.0",
    "next": "16.2.10",
    "playwright-core": "^1.61.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.19"
    }
  },
  "keywords": [
    "material-design",
    "material-3",
    "react",
    "components",
    "ui",
    "design-system"
  ],
  "browserslist": [
    "Chrome >= 120",
    "Edge >= 120",
    "Firefox >= 121",
    "Safari >= 17.2",
    "iOS >= 17.2"
  ]
}
