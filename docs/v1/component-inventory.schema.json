{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://language-lit.dev/material3-expressive/v1/component-inventory.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "components"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "kind", "task", "path", "status", "dependencies", "publicExports"],
        "properties": {
          "name": { "type": "string", "pattern": "^[A-Z][A-Za-z0-9]+$" },
          "kind": { "enum": ["foundation", "action", "containment", "input", "feedback", "overlay", "navigation"] },
          "task": { "type": "string", "pattern": "^T[0-9]{2}$" },
          "path": { "type": "string", "pattern": "^src/v1/" },
          "status": { "enum": ["planned", "experimental", "conformant", "deprecated"] },
          "dependencies": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
          "publicExports": { "type": "array", "items": { "type": "string" }, "minItems": 2, "uniqueItems": true }
        }
      }
    }
  }
}
